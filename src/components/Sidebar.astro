---
import { Building2, BarChart3 } from '@lucide/astro';

const currentPath = Astro.url.pathname;

function isActive(href: string): string {
  return currentPath.startsWith(href) ? 'bg-accent text-accent-foreground' : 'text-muted-foreground hover:bg-accent hover:text-accent-foreground';
}
---
<aside class="hidden md:flex w-56 flex-col border-r bg-sidebar min-h-[calc(100vh-3.5rem)]">
  <nav class="flex flex-col gap-1 p-4">
    <span class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2 px-3">
      Engine
    </span>
    <a
      href="/informes"
      class:list={["flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium transition-colors", isActive("/informes")]}
    >
      <BarChart3 size="18" />
      Informes
    </a>
    <a
      href="/inversiones"
      class:list={["flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium transition-colors", isActive("/inversiones")]}
    >
      <Building2 size="18" />
      Inversiones
    </a>
  </nav>
</aside>
