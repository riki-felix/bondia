---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import BloqueGastosTable from "../../components/bloque/BloqueGastosTable";
import { supabaseClient } from "../../lib/supabaseClient";
import { SANYUS_CONFIG } from "../../lib/bloqueConfig";
import { mapBloqueGastoRow } from "../../lib/bloqueTypes";

const cfg = SANYUS_CONFIG;
const supabase = supabaseClient();
const currentYear = new Date().getFullYear();
const catFilter = Astro.url.searchParams.get("cat");
const activoFilter = Astro.url.searchParams.get("activo");

// Year from query param, default to current
const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get("year");
const ejercicio = yearParam ? Number(yearParam) : currentYear;

// Fetch gastos for selected year
const { data: allGastos, error } = await supabase
  .from(cfg.tables.gastos)
  .select(`*, ${cfg.joins.gastosCateg}, ${cfg.tables.activos}(nombre)`)
  .eq("ejercicio", ejercicio)
  .order("created_at", { ascending: true });

const gastos = ((allGastos ?? []) as any[]).map((r) =>
  mapBloqueGastoRow(r, cfg.tables.gastosCateg, cfg.tables.activos)
);

// Fetch overrides for selected year
const { data: allOverrides } = await supabase
  .from(cfg.tables.gastosOverrides)
  .select("*")
  .eq("ejercicio", ejercicio);

const overrides = allOverrides ?? [];

// Fetch categories
const { data: allCategorias } = await supabase
  .from(cfg.tables.gastosCateg)
  .select("id, nombre, slug, favorito")
  .order("nombre", { ascending: true });

const categorias = allCategorias ?? [];

// Fetch areas + assignments
const [areasRes, areasAssignRes] = await Promise.all([
  supabase.from(cfg.tables.areas).select("*").order("nombre"),
  supabase.from(cfg.tables.areasCategorias).select("*"),
]);

const areas = areasRes.data ?? [];
const areaAssignments = areasAssignRes.data ?? [];

// Fetch payment methods for this block
const { data: allMetodosPago } = await supabase
  .from("metodos_pago")
  .select("*")
  .in("alcance", ["sanyus", "ambos"])
  .eq("activo", true)
  .order("nombre");

const metodosPago = allMetodosPago ?? [];

const { data: allActivos } = await supabase
  .from(cfg.tables.activos)
  .select("id, nombre")
  .order("nombre", { ascending: true });

const activos = allActivos ?? [];
---

<Layout>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight"><span class="text-muted-foreground font-normal">{cfg.label} ·</span> Gastos</h1>
      <p class="text-sm text-muted-foreground">
        Gastos fijos mensuales de Sanyus
      </p>
    </div>

    {error ? (
      <p class="text-destructive">Error: {error.message}</p>
    ) : (
      <BloqueGastosTable
        client:load
        config={cfg}
        initialData={gastos}
        initialOverrides={overrides}
        categorias={categorias}
        initialYear={ejercicio}
        areas={areas}
        areaAssignments={areaAssignments}
        metodosPago={metodosPago}
        activos={activos}
        initialCatFilter={catFilter}
        initialActivoFilter={activoFilter}
      />
    )}
  </div>
  <Toaster client:load />
</Layout>
