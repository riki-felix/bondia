---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import MetodosPagoManager from "../../components/ajustes/MetodosPagoManager";
import ObjetivosSection from "../../components/ajustes/ObjetivosSection";
import BrandingSection from "../../components/ajustes/BrandingSection";
import { supabaseClient } from "../../lib/supabaseClient";
import { brandingStateFromRow } from "../../lib/branding";

const supabase = supabaseClient();

const { data: metodosPago } = await supabase
  .from("metodos_pago")
  .select("*")
  .order("created_at", { ascending: true });

const { data: objetivos } = await supabase
  .from("bondia_objetivos")
  .select("id, etiqueta, valor")
  .order("id", { ascending: true });

const { data: brandingRow } = await supabase
  .from("bondia_branding")
  .select("logo_storage_path, logo_mime_type, updated_at")
  .eq("id", "default")
  .maybeSingle();

const initialBranding = brandingStateFromRow(supabase, brandingRow);
---

<Layout>
  <div class="space-y-6 max-w-3xl">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Ajustes</h1>
      <p class="text-sm text-muted-foreground">
        Configuración global de la plataforma
      </p>
    </div>

    <BrandingSection
      client:load
      initialBranding={initialBranding}
    />

    <MetodosPagoManager
      client:load
      initialData={metodosPago ?? []}
    />

    <ObjetivosSection
      client:load
      initialData={objetivos ?? []}
    />
  </div>
  <Toaster client:load />
</Layout>
