---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import LiquidacionesTable from "../../components/liquidaciones/LiquidacionesTable";
import { supabaseClient } from "../../lib/supabaseClient";

const supabase = supabaseClient();

// Fetch all settlements with joined property name
const { data: allSettlements, error } = await supabase
  .from("liquidaciones")
  .select(
    "id, propiedad_id, fecha_liquidacion, numero_liquidacion, numero_operacion, beneficio_bruto, aportacion, retribucion, retencion, neto, efectivo, transferencia, fecha_transferencia, fecha_aportacion, liquidado, ejercicio, created_at, updated_at, propiedades(titulo, participacion_sanyus)"
  )
  .order("numero_liquidacion", { ascending: true });

// Map the joined data
const settlements = (allSettlements ?? []).map((r: any) => ({
  ...r,
  propiedad_titulo: r.propiedades?.titulo ?? "",
  propiedad_participacion_sanyus: r.propiedades?.participacion_sanyus ?? null,
}));

// Fetch investment properties for the property selector
const { data: propiedades } = await supabase
  .from("propiedades")
  .select("id, titulo, participacion_sanyus")
  .eq("tipo", "inversion")
  .order("numero_operacion", { ascending: true });

const properties = (propiedades ?? []).map((p: any) => ({
  id: p.id,
  titulo: p.titulo || "Sin título",
  participacion_sanyus: p.participacion_sanyus ?? null,
}));

// Compute year range from settlements + properties
const yearSet = new Set<number>();
for (const s of settlements) {
  if (s.ejercicio != null) yearSet.add(s.ejercicio);
}
// Also fetch dates from properties to get the full year range
const { data: propDates } = await supabase
  .from("propiedades")
  .select("ejercicio, fecha_ingreso, created_at")
  .eq("tipo", "inversion");
for (const p of propDates ?? []) {
  if (p.ejercicio != null) yearSet.add(p.ejercicio);
  const dateStr = p.fecha_ingreso || p.created_at;
  if (dateStr) {
    const d = new Date(dateStr);
    if (!Number.isNaN(d.getTime())) yearSet.add(d.getFullYear());
  }
}
const years = Array.from(yearSet).sort((a, b) => b - a);
---

<Layout>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Liquidaciones</h1>
      <p class="text-sm text-muted-foreground">
        Gestión de liquidaciones por propiedad
      </p>
    </div>

    {error ? (
      <p class="text-destructive">Error: {error.message}</p>
    ) : (
      <LiquidacionesTable
        client:load
        initialData={settlements}
        properties={properties}
        years={years}
      />
    )}
  </div>
  <Toaster client:load />
</Layout>
