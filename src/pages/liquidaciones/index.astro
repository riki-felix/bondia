---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import LiquidacionesTable from "../../components/liquidaciones/LiquidacionesTable";
import { supabaseClient } from "../../lib/supabaseClient";

const supabase = supabaseClient();

// Fetch settlements linked to investment properties
const { data: allSettlements, error } = await supabase
  .from("liquidaciones")
  .select(
    "id, propiedad_id, fecha_liquidacion, numero_liquidacion, numero_operacion, beneficio_bruto, aportacion, retribucion, retencion, neto, efectivo, transferencia, fecha_transferencia, fecha_aportacion, liquidado, ejercicio, created_at, updated_at, propiedades!inner(titulo, participacion_sanyus, numero_operacion, tipo)"
  )
  .eq("propiedades.tipo", "inversion")
  .order("numero_operacion", {
    ascending: true,
    nullsFirst: false,
    foreignTable: "propiedades",
  });

// Map the joined data
const settlements = (allSettlements ?? []).map((r: any) => ({
  ...r,
  propiedad_titulo: r.propiedades?.titulo ?? "",
  propiedad_participacion_sanyus: r.propiedades?.participacion_sanyus ?? null,
  propiedad_numero_operacion: r.propiedades?.numero_operacion ?? null,
}));

const propiedadIds = [
  ...new Set(
    settlements
      .map((s: { propiedad_id: string }) => s.propiedad_id)
      .filter(Boolean)
  ),
];

const masterDocumentByPropiedadId: Record<string, string> = {};
if (propiedadIds.length > 0) {
  const { data: masterDocs } = await supabase
    .from("documentos")
    .select("id, entity_id")
    .eq("entity_type", "propiedad")
    .eq("bloque", "engine")
    .eq("folder_slug", "master-liquidacion")
    .in("entity_id", propiedadIds);

  for (const doc of masterDocs ?? []) {
    masterDocumentByPropiedadId[doc.entity_id] = doc.id;
  }
}

// Compute year range from settlements
const yearSet = new Set<number>();
for (const s of settlements) {
  if (s.ejercicio != null) yearSet.add(s.ejercicio);
}
// Also fetch dates from properties to get the full year range
const { data: propDates } = await supabase
  .from("propiedades")
  .select("ejercicio, fecha_ingreso, created_at")
  .eq("tipo", "inversion");
for (const p of propDates ?? []) {
  if (p.ejercicio != null) yearSet.add(p.ejercicio);
  const dateStr = p.fecha_ingreso || p.created_at;
  if (dateStr) {
    const d = new Date(dateStr);
    if (!Number.isNaN(d.getTime())) yearSet.add(d.getFullYear());
  }
}
const years = Array.from(yearSet).sort((a, b) => b - a);

const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get("year");
const currentYear = new Date().getFullYear();
const initialYear =
  yearParam === "all"
    ? null
    : yearParam
      ? Number(yearParam)
      : currentYear;
---

<Layout>
  <div class="space-y-6">
    {error ? (
      <p class="text-destructive">Error: {error.message}</p>
    ) : (
      <LiquidacionesTable
        client:load
        initialData={settlements}
        years={years}
        initialYear={initialYear}
        masterDocumentByPropiedadId={masterDocumentByPropiedadId}
      />
    )}
  </div>
  <Toaster client:load />
</Layout>
