---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import InversionesTable from "../../components/inversiones/InversionesTable";
import { supabaseClient } from "../../lib/supabaseClient";
import type { Property } from "../../lib/propertyTypes";
import {
  collectInversionesYears,
  fetchInversiones,
} from "../../lib/fetchInversiones";

const supabase = supabaseClient();

let inversiones: Property[] = [];
let loadError: string | null = null;
try {
  inversiones = await fetchInversiones(supabase);
} catch (e) {
  loadError = e instanceof Error ? e.message : "Error al cargar inversiones";
}

const years = collectInversionesYears(inversiones);

const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get("year");
const currentYear = new Date().getFullYear();
const initialYear =
  yearParam === "all"
    ? null
    : yearParam
      ? Number(yearParam)
      : currentYear;
---

<Layout>
  <div class="space-y-6">
    {loadError ? (
      <p class="text-destructive">Error: {loadError}</p>
    ) : (
      <InversionesTable
        client:load
        initialData={inversiones}
        years={years}
        initialYear={initialYear}
      />
    )}
  </div>
  <Toaster client:load />
</Layout>
