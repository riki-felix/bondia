---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import InversionesTable from "../../components/inversiones/InversionesTable";
import { supabaseClient } from "../../lib/supabaseClient";
import type { Property } from "../../lib/propertyTypes";
import { PROPERTY_SELECT } from "../../lib/propertyTypes";

const supabase = supabaseClient();

// Fetch all investment properties
const { data: allProperties, error } = await supabase
  .from("propiedades")
  .select(PROPERTY_SELECT)
  .eq("tipo", "inversion")
  .order("numero_operacion", { ascending: true });

// Liquidaciones vinculadas 1:1 a cada inversión (mismo id que la propiedad)
const { data: allLiq } = await supabase
  .from("liquidaciones")
  .select(
    "propiedad_id, aportacion, retribucion, retencion, transferencia, efectivo, fecha_transferencia, ejercicio, liquidado"
  );

const liqByProp = new Map<
  string,
  {
    aportacion: number;
    retribucion: number;
    retencion: number;
    transferencia: number;
    efectivo: number;
    fecha_transferencia: string | null;
    ejercicio: number | null;
    liquidado: boolean;
  }
>();
for (const l of allLiq ?? []) {
  liqByProp.set(l.propiedad_id, {
    aportacion: Number(l.aportacion) || 0,
    retribucion: Number(l.retribucion) || 0,
    retencion: Number(l.retencion) || 0,
    transferencia: Number(l.transferencia) || 0,
    efectivo: Number(l.efectivo) || 0,
    fecha_transferencia: l.fecha_transferencia ?? null,
    ejercicio: l.ejercicio ?? null,
    liquidado: l.liquidado === true,
  });
}

// Totales globales de transferencias (= /liquidaciones)
const { data: allLiqRows } = await supabase
  .from("liquidaciones")
  .select("transferencia, ejercicio");

// Merge liquidación overlay into properties
const properties: Property[] = (allProperties ?? []).map((p: any) => ({
  ...p,
  liq: liqByProp.get(p.id) ?? null,
})) as Property[];

// Extract unique years from ejercicio, fecha_ingreso + ejercicio from liquidaciones
const yearSet = new Set<number>();
properties.forEach((p) => {
  if (p.liq?.ejercicio != null) yearSet.add(p.liq.ejercicio);
  else if (p.ejercicio != null) yearSet.add(p.ejercicio);
  // Fallback to fecha_ingreso/created_at
  const dateStr = p.fecha_ingreso || p.created_at;
  if (dateStr) {
    const d = new Date(dateStr);
    if (!Number.isNaN(d.getTime())) yearSet.add(d.getFullYear());
  }
});
const years = Array.from(yearSet).sort((a, b) => b - a);

// Initial year from query param
const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get("year");
const currentYear = new Date().getFullYear();
const initialYear =
  yearParam === "all"
    ? null
    : yearParam
      ? Number(yearParam)
      : currentYear;
---

<Layout>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Inversiones</h1>
      <p class="text-sm text-muted-foreground">
        Gestión de propiedades de inversión
      </p>
    </div>

    {error ? (
      <p class="text-destructive">Error: {error.message}</p>
    ) : (
      <InversionesTable
        client:load
        initialData={properties}
        years={years}
        initialYear={initialYear}
        liquidacionesTransferencias={(allLiqRows ?? []).map((l) => ({
          transferencia: l.transferencia,
          ejercicio: l.ejercicio,
        }))}
      />
    )}
  </div>
  <Toaster client:load />
</Layout>
