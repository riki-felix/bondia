---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import InversionesTable from "../../components/inversiones/InversionesTable";
import { supabaseClient } from "../../lib/supabaseClient";
import type { Property } from "../../lib/propertyTypes";

const supabase = supabaseClient();

// Fetch all investment properties
const { data: allProperties, error } = await supabase
  .from("propiedades")
  .select(
    "id, numero_operacion, titulo, estado, created_at, pago, aportacion, retribucion, retencion, ingreso_banco, efectivo, jasp_10_percent, transfe, fecha_compra, fecha_venta, ocupado, notas, liquidacion, fecha_ingreso, slug"
  )
  .eq("tipo", "inversion")
  .order("numero_operacion", { ascending: true });

// Fetch liquidaciones aggregated by propiedad_id (only liquidadas)
const { data: allLiq } = await supabase
  .from("liquidaciones")
  .select("propiedad_id, aportacion, retribucion, retencion, transferencia, efectivo, fecha_transferencia, ejercicio")
  .eq("liquidado", true);

// Aggregate liquidaciones per property
const liqByProp = new Map<string, { aportacion: number; retribucion: number; retencion: number; transferencia: number; efectivo: number; fecha_transferencia: string | null; ejercicio: number | null }>();
for (const l of allLiq ?? []) {
  const existing = liqByProp.get(l.propiedad_id) ?? { aportacion: 0, retribucion: 0, retencion: 0, transferencia: 0, efectivo: 0, fecha_transferencia: null, ejercicio: null };
  existing.aportacion += Number(l.aportacion) || 0;
  existing.retribucion += Number(l.retribucion) || 0;
  existing.retencion += Number(l.retencion) || 0;
  existing.transferencia += Number(l.transferencia) || 0;
  existing.efectivo += Number(l.efectivo) || 0;
  if (l.fecha_transferencia) existing.fecha_transferencia = l.fecha_transferencia;
  if (l.ejercicio != null) existing.ejercicio = l.ejercicio;
  liqByProp.set(l.propiedad_id, existing);
}

// Merge liquidación overlay into properties
const properties: Property[] = (allProperties ?? []).map((p: any) => ({
  ...p,
  liq: liqByProp.get(p.id) ?? null,
})) as Property[];

// Extract unique years from fecha_ingreso + ejercicio from liquidaciones
const yearSet = new Set<number>();
properties.forEach((p) => {
  const dateStr = p.fecha_ingreso || p.created_at;
  if (!dateStr) return;
  const d = new Date(dateStr);
  if (!Number.isNaN(d.getTime())) yearSet.add(d.getFullYear());
  // Also include ejercicio from linked liquidación
  if (p.liq?.ejercicio != null) yearSet.add(p.liq.ejercicio);
});
const years = Array.from(yearSet).sort((a, b) => b - a);

// Initial year from query param
const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get("year");
const currentYear = new Date().getFullYear();
const initialYear =
  yearParam === "all"
    ? null
    : yearParam
      ? Number(yearParam)
      : currentYear;
---

<Layout>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Inversiones</h1>
      <p class="text-sm text-muted-foreground">
        Gestión de propiedades de inversión
      </p>
    </div>

    {error ? (
      <p class="text-destructive">Error: {error.message}</p>
    ) : (
      <InversionesTable
        client:load
        initialData={properties}
        years={years}
        initialYear={initialYear}
      />
    )}
  </div>
  <Toaster client:load />
</Layout>
