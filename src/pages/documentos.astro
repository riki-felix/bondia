---
export const prerender = false;

import Layout from "../components/Layout.astro";
import { Toaster } from "../components/ui/sonner";
import DocumentsExplorer from "../components/documents/DocumentsExplorer";
---

<Layout title="Documentos">
  <Toaster client:load />
  <div class="mb-6">
    <h1 class="text-2xl font-semibold tracking-tight">Documentos</h1>
    <p class="text-sm text-muted-foreground mt-1">
      Archivos privados organizados por Engine, Casa y Sanyus. Las URLs de descarga son temporales.
    </p>
  </div>
  <DocumentsExplorer client:load />
</Layout>
