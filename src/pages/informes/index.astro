---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import InformesDashboard from "../../components/informes/InformesDashboard";
import { supabaseClient } from "../../lib/supabaseClient";
import type { InformesProperty } from "../../lib/informesStats";
import { maxInformesUpdatedAt } from "../../lib/informesStats";
import { fetchMercadoReferencia } from "../../lib/mercadoReferencia";
import { PROPERTY_SELECT } from "../../lib/propertyTypes";
import {
  OBJETIVO_BENEFICIO_MEDIO_OPERACION,
  objetivoValorFromRow,
  type Objetivo,
} from "../../lib/objetivos";

const supabase = supabaseClient();

const { data: allProperties, error } = await supabase
  .from("propiedades")
  .select(
    `${PROPERTY_SELECT}, precio_compra, precio_venta, superficie_registrada_m2, direccion, updated_at`
  )
  .eq("tipo", "inversion")
  .order("numero_operacion", { ascending: true });

let mercadoReferencia = null;
try {
  mercadoReferencia = await fetchMercadoReferencia(supabase);
} catch (e) {
  console.error("[informes] mercado referencia:", e);
}

const { data: allLiq } = await supabase
  .from("liquidaciones")
  .select(
    "propiedad_id, aportacion, retribucion, retencion, transferencia, efectivo, fecha_transferencia, ejercicio, liquidado, updated_at"
  );

const liqByProp = new Map<
  string,
  {
    aportacion: number;
    retribucion: number;
    retencion: number;
    transferencia: number;
    efectivo: number;
    fecha_transferencia: string | null;
    ejercicio: number | null;
    liquidado: boolean;
  }
>();
for (const l of allLiq ?? []) {
  liqByProp.set(l.propiedad_id, {
    aportacion: Number(l.aportacion) || 0,
    retribucion: Number(l.retribucion) || 0,
    retencion: Number(l.retencion) || 0,
    transferencia: Number(l.transferencia) || 0,
    efectivo: Number(l.efectivo) || 0,
    fecha_transferencia: l.fecha_transferencia ?? null,
    ejercicio: l.ejercicio ?? null,
    liquidado: l.liquidado === true,
  });
}

const properties: InformesProperty[] = (allProperties ?? []).map((p: any) => ({
  ...p,
  precio_compra: p.precio_compra ?? null,
  precio_venta: p.precio_venta ?? null,
  superficie_registrada_m2: p.superficie_registrada_m2 ?? null,
  direccion: p.direccion ?? null,
  liq: liqByProp.get(p.id) ?? null,
})) as InformesProperty[];

const { data: objetivosRows } = await supabase
  .from("bondia_objetivos")
  .select("id, etiqueta, valor")
  .eq("id", OBJETIVO_BENEFICIO_MEDIO_OPERACION)
  .maybeSingle();

const objetivoBeneficioMedio = objetivoValorFromRow(
  objetivosRows ? [objetivosRows as Objetivo] : [],
  OBJETIVO_BENEFICIO_MEDIO_OPERACION
);

const lastUpdatedAt = maxInformesUpdatedAt(
  allProperties ?? [],
  allLiq ?? []
);
---

<Layout>
  <div class="space-y-6">
    {error ? (
      <p class="text-destructive">Error: {error.message}</p>
    ) : (
      <InformesDashboard
        client:load
        initialData={properties}
        lastUpdatedAt={lastUpdatedAt}
        objetivoBeneficioMedio={objetivoBeneficioMedio}
        mercadoReferencia={mercadoReferencia}
      />
    )}
  </div>
  <Toaster client:load />
</Layout>
