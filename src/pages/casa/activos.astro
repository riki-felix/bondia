---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import BloqueActivosTable from "../../components/bloque/BloqueActivosTable";
import { supabaseClient } from "../../lib/supabaseClient";
import { CASA_CONFIG } from "../../lib/bloqueConfig";

const cfg = CASA_CONFIG;
const supabase = supabaseClient();
const catFilter = Astro.url.searchParams.get("cat");

// Fetch all activos
const { data: allActivos, error } = await supabase
  .from(cfg.tables.activos)
  .select(`*, ${cfg.joins.activosCateg}`)
  .order("created_at", { ascending: true });

const activos = (allActivos ?? []).map((r: any) => ({
  ...r,
  categoria_nombre: r[cfg.tables.activosCateg]?.nombre ?? "",
}));

// Fetch categories
const { data: allCategorias } = await supabase
  .from(cfg.tables.activosCateg)
  .select("id, nombre, slug, favorito")
  .order("nombre", { ascending: true });

const categorias = allCategorias ?? [];

// Fetch tags + assignments
const [tagsRes, tagsRelRes] = await Promise.all([
  supabase.from(cfg.tables.activosTagCatalog!).select("*").order("nombre"),
  supabase.from(cfg.tables.activosTagsJoin!).select("*"),
]);
const allTags = tagsRes.data ?? [];
const tagsRel = tagsRelRes.data ?? [];

// Map tag assignments onto activos
const tagsByActivo = new Map<string, any[]>();
for (const rel of tagsRel) {
  const tag = allTags.find((t: any) => t.id === rel.tag_id);
  if (!tag) continue;
  if (!tagsByActivo.has(rel.activo_id)) tagsByActivo.set(rel.activo_id, []);
  tagsByActivo.get(rel.activo_id)!.push(tag);
}
const activosWithTags = activos.map((a: any) => ({
  ...a,
  tags: tagsByActivo.get(a.id) ?? [],
}));

const tagFilter = Astro.url.searchParams.get("tag");
---

<Layout>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight"><span class="text-muted-foreground font-normal">{cfg.label} ·</span> Activos</h1>
      <p class="text-sm text-muted-foreground">
        Listado de activos y patrimonio
      </p>
    </div>

    {error ? (
      <p class="text-destructive">Error: {error.message}</p>
    ) : (
      <BloqueActivosTable
        client:load
        config={cfg}
        initialData={activosWithTags}
        categorias={categorias}
        initialCatFilter={catFilter}
        allTags={allTags}
        initialTagFilter={tagFilter}
      />
    )}
  </div>
  <Toaster client:load />
</Layout>
