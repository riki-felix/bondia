---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import CasaControlDashboard from "../../components/casa/CasaControlDashboard";
import { supabaseClient } from "../../lib/supabaseClient";

const supabase = supabaseClient();
const now = new Date();
const ejercicio = now.getFullYear();
const mesActual = now.getMonth() + 1; // 1-12

// Fetch gastos + overrides
const [gastosRes, gastosOvRes, ingresosRes, ingresosOvRes, areasRes, aaRes] =
  await Promise.all([
    supabase
      .from("casa_gastos")
      .select("*, casa_gastos_categorias(nombre)")
      .eq("ejercicio", ejercicio)
      .order("created_at", { ascending: true }),
    supabase
      .from("casa_gastos_overrides")
      .select("*")
      .eq("ejercicio", ejercicio),
    supabase
      .from("casa_ingresos")
      .select("*, casa_ingresos_categorias(nombre)")
      .eq("ejercicio", ejercicio)
      .order("created_at", { ascending: true }),
    supabase
      .from("casa_ingresos_overrides")
      .select("*")
      .eq("ejercicio", ejercicio),
    supabase.from("casa_areas").select("*").order("nombre"),
    supabase.from("casa_areas_categorias").select("*"),
  ]);

const gastos = (gastosRes.data ?? []).map((r: any) => ({
  ...r,
  categoria_nombre: r.casa_gastos_categorias?.nombre ?? "",
}));
const gastosOverrides = gastosOvRes.data ?? [];

const ingresos = (ingresosRes.data ?? []).map((r: any) => ({
  ...r,
  categoria_nombre: r.casa_ingresos_categorias?.nombre ?? "",
}));
const ingresosOverrides = ingresosOvRes.data ?? [];

const areas = areasRes.data ?? [];
const areaAssignments = aaRes.data ?? [];
---

<Layout>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Control</h1>
      <p class="text-sm text-muted-foreground">
        Dashboard de la casa — {ejercicio}
      </p>
    </div>

    <CasaControlDashboard
      client:load
      gastos={gastos}
      gastosOverrides={gastosOverrides}
      ingresos={ingresos}
      ingresosOverrides={ingresosOverrides}
      ejercicio={ejercicio}
      mesActual={mesActual}
      areas={areas}
      areaAssignments={areaAssignments}
    />
  </div>
  <Toaster client:load />
</Layout>
