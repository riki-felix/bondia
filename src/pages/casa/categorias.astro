---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import BloqueCategoriasManager from "../../components/bloque/BloqueCategoriasManager";
import BloqueAreasManager from "../../components/bloque/BloqueAreasManager";
import BloqueActivoTagsManager from "../../components/bloque/BloqueActivoTagsManager";
import BloqueActivoCaracteristicasManager from "../../components/bloque/BloqueActivoCaracteristicasManager";
import { supabaseClient } from "../../lib/supabaseClient";
import { CASA_CONFIG } from "../../lib/bloqueConfig";

const cfg = CASA_CONFIG;
const supabase = supabaseClient();

// Fetch all three category types + areas in parallel
const [gastoRes, ingresoRes, activoRes, areasRes, areasCategoriasRes, tagsRes, caracRes] = await Promise.all([
  supabase.from(cfg.tables.gastosCateg).select("id, nombre, slug, favorito").order("nombre"),
  supabase.from(cfg.tables.ingresosCateg).select("id, nombre, slug, favorito").order("nombre"),
  supabase.from(cfg.tables.activosCateg).select("id, nombre, slug, favorito").order("nombre"),
  supabase.from(cfg.tables.areas).select("*").order("nombre"),
  supabase.from(cfg.tables.areasCategorias).select("*"),
  supabase.from(cfg.tables.activosTagCatalog!).select("*").order("nombre"),
  supabase.from(cfg.tables.activosCaracteristicas!).select("*").order("nombre"),
]);

const gastoCategorias = gastoRes.data ?? [];
const ingresoCategorias = ingresoRes.data ?? [];
const activoCategorias = activoRes.data ?? [];
const areas = areasRes.data ?? [];
const areasAssignments = areasCategoriasRes.data ?? [];
const activoTags = tagsRes.data ?? [];
const activoCaracteristicas = caracRes.data ?? [];
---

<Layout>
  <div class="space-y-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight"><span class="text-muted-foreground font-normal">{cfg.label} ·</span> Categorías y Áreas</h1>
      <p class="text-sm text-muted-foreground">
        Gestión de categorías para gastos, ingresos y activos. Las áreas agrupan categorías para filtrar las tablas.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Categorías (izquierda) -->
      <div>
        <h2 class="text-lg font-semibold tracking-tight mb-3">Categorías</h2>
        <BloqueCategoriasManager
          client:load
          config={cfg}
          gastoCategorias={gastoCategorias}
          ingresoCategorias={ingresoCategorias}
          activoCategorias={activoCategorias}
        />
      </div>

      <!-- Áreas (derecha) -->
      <div>
        <h2 class="text-lg font-semibold tracking-tight mb-1">Áreas</h2>
        <p class="text-sm text-muted-foreground mb-3">
          Agrupa categorías para filtrar gastos e ingresos.
        </p>
        <BloqueAreasManager
          client:load
          config={cfg}
          initialAreas={areas}
          initialAssignments={areasAssignments}
          gastoCategorias={gastoCategorias}
          ingresoCategorias={ingresoCategorias}
          activoCategorias={activoCategorias}
        />
      </div>
    </div>

    <!-- Tags de activos -->
    <div>
      <h2 class="text-lg font-semibold tracking-tight mb-1">Tags de activos</h2>
      <p class="text-sm text-muted-foreground mb-3">
        Etiquetas para organizar activos de Casa (ej: colecciones, series).
      </p>
      <BloqueActivoTagsManager
        client:load
        config={cfg}
        initialTags={activoTags}
      />
    </div>

    <!-- Características de activos -->
    <div>
      <h2 class="text-lg font-semibold tracking-tight mb-1">Características de activos</h2>
      <p class="text-sm text-muted-foreground mb-3">
        Campos personalizados para activos de Casa (ej: tamaño, unidades). Se pueden asociar a una categoría concreta.
      </p>
      <BloqueActivoCaracteristicasManager
        client:load
        config={cfg}
        initialCaracteristicas={activoCaracteristicas}
        activoCategorias={activoCategorias}
      />
    </div>
  </div>
  <Toaster client:load />
</Layout>
