---
export const prerender = false;

import Layout from "../../../components/Layout.astro";
import { Toaster } from "../../../components/ui/sonner";
import BloqueActivoDetail from "../../../components/bloque/BloqueActivoDetail";
import { supabaseClient } from "../../../lib/supabaseClient";
import { CASA_CONFIG } from "../../../lib/bloqueConfig";
import { isCasaActivoTitular } from "../../../lib/casaActivoTitular";

const cfg = CASA_CONFIG;
const supabase = supabaseClient();
const titularParam = Astro.url.searchParams.get("titular");
const defaultTitular = isCasaActivoTitular(titularParam) ? titularParam : null;

// Fetch categories for the select
const { data: allCategorias } = await supabase
  .from(cfg.tables.activosCateg)
  .select("id, nombre, slug, favorito")
  .order("nombre", { ascending: true });

const categorias = allCategorias ?? [];

const { data: tagsData } = await supabase
  .from(cfg.tables.activosTagCatalog!)
  .select("*")
  .order("nombre");
const allTags = tagsData ?? [];

const { data: caracData } = await supabase
  .from(cfg.tables.activosCaracteristicas!)
  .select("*")
  .order("nombre");
const allCaracteristicas = caracData ?? [];
---

<Layout>
  <BloqueActivoDetail
    client:load
    config={cfg}
    categorias={categorias}
    allTags={allTags}
    allCaracteristicas={allCaracteristicas}
    defaultTitular={defaultTitular}
  />
  <Toaster client:load />
</Layout>
