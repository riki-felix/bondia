---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import PropertyDetail from "../../components/propiedades/PropertyDetail";
import { supabaseClient } from "../../lib/supabaseClient";
import { PROPERTY_IMAGES_BUCKET } from "../../lib/propertyStorage";

const { id } = Astro.params;
if (!id) return Astro.redirect("/propiedades");

const supabase = supabaseClient();

const { data: property, error } = await supabase
  .from("propiedades")
  .select(
    "id, titulo, origen, direccion, estado, ejercicio, created_at, liquidacion, ocupado, foto_destacada_path, precio_compra, precio_venta, superficie_m2, superficie_registrada_m2, superficie_real_m2, anio_construccion, numero_catastro, catastro_referencia_validada, catastro_validado_at, fecha_ingreso, fecha_compra, fecha_venta, numero_operacion, pago, participacion_sanyus, participacion_jasp, participacion_bienes_sanyus_cb, aportacion, retribucion, retencion, ingreso_banco, efectivo, jasp_10_percent, jasp_manual, notas, slug, beneficio_bruto, fecha_liquidacion, fecha_aportacion, fecha_transferencia, numero_op_liquidacion, liquidada_at"
  )
  .eq("id", id)
  .single();

if (error || !property) return Astro.redirect("/propiedades");

let imageUrl: string | null = null;
if (property.foto_destacada_path) {
  const { data: urlData } = supabase.storage
    .from(PROPERTY_IMAGES_BUCKET)
    .getPublicUrl(property.foto_destacada_path);
  imageUrl = urlData?.publicUrl ?? null;
}
---

<Layout>
  <div class="space-y-6">
    <PropertyDetail
      client:load
      property={property}
      imageUrl={imageUrl}
    />
  </div>
  <Toaster client:load />
</Layout>
