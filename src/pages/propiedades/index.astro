---
export const prerender = false;

import Layout from "../../components/Layout.astro";
import { Toaster } from "../../components/ui/sonner";
import PropiedadesGrid from "../../components/propiedades/PropiedadesGrid";
import { supabaseClient } from "../../lib/supabaseClient";
import type { PropertyCard } from "../../components/propiedades/PropiedadesGrid";

const supabase = supabaseClient();

const { data: allProperties, error } = await supabase
  .from("propiedades")
  .select(
    "id, titulo, estado, created_at, ejercicio, liquidacion, foto_destacada_path, transfe, slug, fecha_transferencia"
  )
  .eq("tipo", "inversion")
  .order("created_at", { ascending: false });

const properties: PropertyCard[] = (allProperties ?? []).map((p: any) => ({
  id: p.id,
  titulo: p.titulo,
  estado: p.estado,
  created_at: p.created_at,
  ejercicio: p.ejercicio,
  liquidacion: !!p.liquidacion,
  foto_destacada_path: p.foto_destacada_path,
  fecha_transferencia: p.fecha_transferencia ?? null,
}));

const yearSet = new Set<number>();
for (const p of properties) {
  if (p.ejercicio != null) yearSet.add(p.ejercicio);
  if (p.created_at) {
    const d = new Date(p.created_at);
    if (!isNaN(d.getTime())) yearSet.add(d.getFullYear());
  }
}
const years = Array.from(yearSet).sort((a, b) => b - a);

const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get("year");
const currentYear = new Date().getFullYear();
const initialYear =
  yearParam === "all"
    ? null
    : yearParam
      ? Number(yearParam)
      : currentYear;
---

<Layout>
  <div class="space-y-6">
    {error ? (
      <p class="text-destructive">Error: {error.message}</p>
    ) : (
      <PropiedadesGrid
        client:load
        initialData={properties}
        years={years}
        initialYear={initialYear}
      />
    )}
  </div>
  <Toaster client:load />
</Layout>
